# AMQP 1.0 endpoint used for messaging (send/browse/consume).
ARTEMIS_AMQP_URL=amqp://localhost:5672

# Jolokia REST endpoint exposed by the Artemis console, used for
# management, monitoring and admin operations.
ARTEMIS_JOLOKIA_URL=http://localhost:8161/console/jolokia

# Broker credentials. The same pair is used for AMQP and Jolokia unless
# the *_AMQP_* / *_JOLOKIA_* overrides below are set.
ARTEMIS_USER=artemis
ARTEMIS_PASSWORD=artemis

# Broker name as registered in the Artemis ObjectName. Defaults to the
# value Artemis uses out of the box.
ARTEMIS_BROKER_NAME=0.0.0.0

# Access mode: "read-only" (default) exposes only non-destructive tools.
# "admin" additionally exposes purge/move/delete/retry, each still gated
# behind an explicit confirm flag.
ARTEMIS_MODE=read-only

# Upper bound on messages returned by browse_messages, regardless of the
# per-call limit requested by the client.
ARTEMIS_MAX_BROWSE=200

# Network timeouts in milliseconds.
ARTEMIS_JOLOKIA_TIMEOUT_MS=10000
ARTEMIS_AMQP_TIMEOUT_MS=15000
