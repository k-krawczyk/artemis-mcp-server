{
  "name": "artemis-mcp-server",
  "version": "0.1.1",
  "description": "Model Context Protocol server for ActiveMQ Artemis: messaging over AMQP and broker management over Jolokia.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "activemq",
    "artemis",
    "amqp",
    "jolokia",
    "messaging"
  ],
  "license": "MIT",
  "author": "Karol Krawczyk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k-krawczyk/artemis-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/k-krawczyk/artemis-mcp-server/issues"
  },
  "homepage": "https://github.com/k-krawczyk/artemis-mcp-server#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "artemis-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "rhea": "^3.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "testcontainers": "^12.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  }
}
